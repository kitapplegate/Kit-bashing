---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Kit Bashing</h1>
			<p>
				A field log of AI, networking, and questionable decisions — one retired Coast Guard hazmat guy's
				path from vessel inspections to CCNA to building a home lab from scratch, out loud, in public.
			</p>
			<p>
				New posts go up roughly weekly over in the <a href="/blog/">blog</a>. Start there.
			</p>
		</main>
		<Footer />
	</body>
</html>
